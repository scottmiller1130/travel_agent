# ─────────────────────────────────────────────────────────────────────────────
# Travel Agent — Environment Variables
# Copy this file to .env and fill in your values, or set in Railway Variables.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED ────────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# BACKUPS — Cloudflare R2 (strongly recommended — free tier covers years of dailys)
# Without this: no external backup exists. If Railway loses the database, data is gone.
# With this:    full database exported daily to R2; 30-day rolling history kept.
#
# Setup:
#   1. Cloudflare dashboard → R2 → Create bucket (name: travelagentbackup)
#   2. R2 → Manage R2 API Tokens → Create Token
#      Permissions: Object Read & Write on the bucket above
#   3. Copy Account ID, Access Key ID, and Secret Access Key
#   4. Add all four variables to Railway Variables (not here — never commit secrets)
#
# Recovery (if database is lost):
#   GET  /api/admin/r2-backups           — list available backups
#   POST /api/admin/r2-restore           — restore {"key": "backup_2026-...Z.json.gz"}
#   POST /api/admin/r2-backups           — trigger a manual backup now
#
R2_ACCOUNT_ID=d4c02e3f19f1dba5ed78a364881b86b4
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=travelagentbackup


# DATABASE — required for persistence ─────────────────────────────────────────
# Supabase (free tier): https://supabase.com
#   1. Create a new project
#   2. Go to Settings → Database → Connection string → URI
#   3. Copy the "Session mode" URI (port 5432) and paste below
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres


# FLIGHTS — Google Flights via SerpAPI (recommended, real live prices) ────────
# SerpAPI scrapes Google Flights and returns structured JSON.
# 100 free searches/month. Production: $50/mo for 5,000 searches.
# Sign up at https://serpapi.com/ → Dashboard → API Key
SERPAPI_KEY=

# FLIGHTS — Amadeus GDS (alternative / fallback) ──────────────────────────────
# Free sandbox, no credit card: https://developers.amadeus.com/
# AMADEUS_HOST: test.api.amadeus.com (default) or api.amadeus.com (production)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_HOST=https://test.api.amadeus.com

# FLIGHTS + HOTELS — Travelpayouts Affiliate (free, real cached pricing) ───────
# Free affiliate API covering flights (Aviasales) and hotels (Hotellook).
# Flights: real cached prices from millions of Aviasales user searches.
# Hotels: 250,000+ hotels with cached OTA pricing (Booking.com, Agoda, etc.)
# Sign up free at https://www.travelpayouts.com/developers/api
# Token: https://www.travelpayouts.com/programs/100/tools/api
TRAVELPAYOUTS_TOKEN=


# AUTH — Clerk (user accounts, login, per-user data isolation) ────────────────
# Sign up at https://clerk.com → Create application → API Keys
#
# CLERK_PUBLISHABLE_KEY      → shown in browser (safe to expose), starts with pk_
#                               REQUIRED to enable auth. JWKS URL is auto-derived.
#
# CLERK_JWT_VERIFICATION_KEY → RECOMMENDED for production. The RSA public key used
#                               to verify JWTs without any outbound network calls.
#   How to get it: Clerk Dashboard → API Keys → Show JWT Public Key → copy PEM.
#   Paste the entire PEM block (including -----BEGIN/END----- lines) as one value.
#   This is the most reliable option — no dependency on Clerk's JWKS endpoint.
#
# CLERK_JWKS_URL             → Optional alternative. Auto-derived from publishable
#                               key if not set. Only needed to override the URL.
#   Format: https://<your-frontend-api>/.well-known/jwks.json
#
# Without CLERK_PUBLISHABLE_KEY the app runs in anonymous mode.
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_VERIFICATION_KEY=
CLERK_JWKS_URL=


# WEB SEARCH — optional upgrade ───────────────────────────────────────────────
# Without this: uses Wikipedia (works, no key needed)
# With this:    uses Brave full web search (better travel research results)
# Free tier: 2,000 queries/month — https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=


# HOSTELS — Hostelworld Affiliate API (real hostel & dorm inventory) ──────────
# Best source for hostel/dorm pricing, vibe tags, amenity data (common room, kitchen)
# Apply at: https://www.hostelworld.com/info/affiliates
# When set: real hostel prices replace estimated pricing for accommodation_type=hostel/dorm
HOSTELWORLD_API_KEY=


# HOTELS — Booking.com Affiliate API (full spectrum: luxury to hostels) ───────
# Required for real luxury hotel inventory (Four Seasons, Aman, Ritz-Carlton, etc.)
# Also covers mid-range, guesthouses, and hostels with real availability data
# Apply at: https://join.booking.com/affiliateprogram/welcome/
# When set: replaces estimated hotel pricing with live rates and real availability
BOOKING_COM_API_KEY=


# EXPERIENCES — Viator Partner API (300k+ bookable tours & activities) ─────────
# Best source for bookable experiences: day trips, tours, cooking classes, etc.
# Apply free at: https://partnerresources.viator.com/ (affiliate program)
# When set: real bookable experience listings with prices, reviews, booking links
VIATOR_API_KEY=

# EXPERIENCES — GetYourGuide Partner API (60k+ tours & activities) ──────────────
# Alternative experiences source: walking tours, museums, adventure activities
# Apply free at: https://partner.getyourguide.com/ (affiliate program)
# When set: supplements Viator with additional local experience options
GETYOURGUIDE_API_KEY=

# EXPERIENCES — OpenTripMap (free, no key required) ────────────────────────────
# Provides real attraction names and POIs for experience suggestions.
# Sign up for higher rate limits at https://opentripmap.io/product
# Works without a key at ~1,000 requests/day from shared pool.
OPENTRIPMAP_KEY=


# NO KEY NEEDED (work automatically) ─────────────────────────────────────────
# Weather         → Open-Meteo          https://open-meteo.com
# Places          → OpenStreetMap       https://www.openstreetmap.org
# Distances       → Nominatim / OSM     https://nominatim.openstreetmap.org
# Experiences     → OpenTripMap         https://opentripmap.io (no key needed)
