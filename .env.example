# ─────────────────────────────────────────────────────────────────────────────
# Travel Agent — Environment Variables
# Copy this file to .env and fill in your values, or set in Railway Variables.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED ────────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# DATABASE — required for persistence ─────────────────────────────────────────
# Supabase (free tier): https://supabase.com
#   1. Create a new project
#   2. Go to Settings → Database → Connection string → URI
#   3. Copy the "Session mode" URI (port 5432) and paste below
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres


# FLIGHTS — Google Flights via SerpAPI (recommended, real live prices) ────────
# SerpAPI scrapes Google Flights and returns structured JSON.
# 100 free searches/month. Production: $50/mo for 5,000 searches.
# Sign up at https://serpapi.com/ → Dashboard → API Key
SERPAPI_KEY=

# FLIGHTS — Amadeus GDS (alternative / fallback) ──────────────────────────────
# Free sandbox, no credit card: https://developers.amadeus.com/
# AMADEUS_HOST: test.api.amadeus.com (default) or api.amadeus.com (production)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_HOST=https://test.api.amadeus.com


# AUTH — Clerk (user accounts, login, per-user data isolation) ────────────────
# Sign up at https://clerk.com → Create application → API Keys
#
# CLERK_PUBLISHABLE_KEY  → shown in browser (safe to expose), starts with pk_
# CLERK_JWKS_URL         → used by the backend to verify JWT tokens
#   Format: https://<your-frontend-api>/.well-known/jwks.json
#   Find your Frontend API URL in the Clerk Dashboard → API Keys
#
# Without these, the app runs in anonymous mode (all features still work).
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=


# WEB SEARCH — optional upgrade ───────────────────────────────────────────────
# Without this: uses Wikipedia (works, no key needed)
# With this:    uses Brave full web search (better travel research results)
# Free tier: 2,000 queries/month — https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=


# HOSTELS — Hostelworld Affiliate API (real hostel & dorm inventory) ──────────
# Best source for hostel/dorm pricing, vibe tags, amenity data (common room, kitchen)
# Apply at: https://www.hostelworld.com/info/affiliates
# When set: real hostel prices replace estimated pricing for accommodation_type=hostel/dorm
HOSTELWORLD_API_KEY=


# HOTELS — Booking.com Affiliate API (full spectrum: luxury to hostels) ───────
# Required for real luxury hotel inventory (Four Seasons, Aman, Ritz-Carlton, etc.)
# Also covers mid-range, guesthouses, and hostels with real availability data
# Apply at: https://join.booking.com/affiliateprogram/welcome/
# When set: replaces estimated hotel pricing with live rates and real availability
BOOKING_COM_API_KEY=


# NO KEY NEEDED (work automatically) ─────────────────────────────────────────
# Weather    → Open-Meteo          https://open-meteo.com
# Places     → OpenStreetMap       https://www.openstreetmap.org
# Distances  → Nominatim / OSM     https://nominatim.openstreetmap.org
